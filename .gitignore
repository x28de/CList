# OS / editor artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Sensitive local config
*.env
*.local

# mkcert TLS certificates (machine-local, never commit the private key)
certs/

# Runtime state
.launcher-port

# PyInstaller build output
CList.spec
build/
dist/

# Node (if ever used for tooling)
node_modules/

# Bundled build tools (downloaded by build scripts, not committed)
tools/

# Extension build artifacts (zip packages are published via web, not git)
*.zip
