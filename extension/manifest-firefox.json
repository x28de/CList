{
  "manifest_version": 3,
  "name": "CList Annotate & Collect",
  "version": "0.3.0",
  "description": "Annotate and collect web pages into your CList account from any tab.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "CList Annotate & Collect",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "permissions": ["activeTab", "storage", "tabs"],

  "host_permissions": ["*://*/*"],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },

  "sidebar_action": {
    "default_panel": "popup.html?mode=sidebar",
    "default_title": "CList Annotate & Collect",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
