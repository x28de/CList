<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1448" height="1086" viewBox="0 0 1448 1086" role="img" aria-labelledby="title desc">
  <title id="title">People want to talk to People</title>
  <desc id="desc">Minimal typographic word art: large People on the left and right, with want to and talk to stacked between them.</desc>
  <rect width="100%" height="100%" fill="#ffffff"/>
  <g fill="#4caf50" font-family="Arial, Helvetica, sans-serif" font-weight="700">
    <text x="45" y="585" font-size="255">People</text>
    <text x="885" y="585" font-size="255">People</text>
    <text x="595" y="485" font-size="86">want to</text>
    <text x="615" y="585" font-size="86">talk to</text>
  </g>
</svg>
